<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/player_info_panel"
        android:layout_width="@dimen/player_side_panel_width"
        android:layout_height="0dp"
        android:layout_margin="@dimen/player_side_panel_margin"
        android:layout_marginTop="@dimen/player_side_panel_margin_top"
        android:layout_marginBottom="@dimen/player_side_panel_margin_bottom"
        android:visibility="gone"
        app:cardBackgroundColor="#CC171A1E"
        app:cardCornerRadius="@dimen/player_side_panel_corner_radius"
        app:cardElevation="@dimen/player_side_panel_elevation"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/player_side_panel_padding">

            <LinearLayout
                android:id="@+id/row_player_info_tabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tab_player_info_intro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_info_intro"
                    android:textColor="@color/blbl_pink"
                    android:textSize="@dimen/player_info_tab_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tab_player_info_comments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/player_info_tab_gap"
                    android:text="@string/player_btn_comments"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="@dimen/player_info_tab_text_size" />
            </LinearLayout>

            <View
                android:id="@+id/divider_player_info_tabs"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:background="#14FFFFFF"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/row_player_info_tabs" />

            <androidx.core.widget.NestedScrollView
                android:id="@+id/scroll_player_info"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:fillViewport="true"
                android:overScrollMode="never"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider_player_info_tabs">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="14dp"
                    android:paddingBottom="6dp">

                    <LinearLayout
                        android:id="@+id/btn_player_info_up_profile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_player_info_avatar"
                            android:layout_width="@dimen/player_info_avatar_size"
                            android:layout_height="@dimen/player_info_avatar_size"
                            android:contentDescription="@string/player_up_quick_open_profile"
                            android:src="@android:drawable/sym_def_app_icon"
                            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay_Blbl_Circular"
                            app:strokeColor="#80FFFFFF"
                            app:strokeWidth="1dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_player_info_up_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="@dimen/player_info_up_name_text_size"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_player_info_up_meta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="@dimen/player_info_up_meta_text_size" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/btn_player_info_follow"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:background="?attr/blblFocusBgRound"
                            android:gravity="center"
                            android:minWidth="@dimen/player_info_follow_min_width"
                            android:paddingStart="@dimen/player_info_follow_padding_h"
                            android:paddingEnd="@dimen/player_info_follow_padding_h"
                            android:text="@string/player_up_quick_follow"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/player_info_follow_text_size" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_player_info_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/player_info_title_text_size"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_player_info_stats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="@dimen/player_info_stats_text_size" />

                    <TextView
                        android:id="@+id/tv_player_info_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:ellipsize="end"
                        android:maxLines="3"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="@dimen/player_info_desc_text_size" />

                    <LinearLayout
                        android:id="@+id/row_player_info_actions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:baselineAligned="false"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/action_player_info_like"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="?attr/blblFocusBgRound"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingHorizontal="@dimen/player_info_action_padding_h"
                            android:paddingVertical="@dimen/player_info_action_padding_v">

                            <ImageView
                                android:id="@+id/iv_player_info_like"
                                android:layout_width="@dimen/player_info_action_icon_size"
                                android:layout_height="@dimen/player_info_action_icon_size"
                                android:contentDescription="@string/app_name"
                                android:src="@drawable/ic_action_like"
                                app:tint="@color/player_button_tint" />

                            <TextView
                                android:id="@+id/tv_player_info_like"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="@dimen/player_info_action_text_size" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/action_player_info_coin"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="?attr/blblFocusBgRound"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingHorizontal="@dimen/player_info_action_padding_h"
                            android:paddingVertical="@dimen/player_info_action_padding_v">

                            <ImageView
                                android:id="@+id/iv_player_info_coin"
                                android:layout_width="@dimen/player_info_action_icon_size"
                                android:layout_height="@dimen/player_info_action_icon_size"
                                android:contentDescription="@string/app_name"
                                android:src="@drawable/ic_action_coin"
                                app:tint="@color/player_button_tint" />

                            <TextView
                                android:id="@+id/tv_player_info_coin"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="@dimen/player_info_action_text_size" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/action_player_info_fav"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="?attr/blblFocusBgRound"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingHorizontal="@dimen/player_info_action_padding_h"
                            android:paddingVertical="@dimen/player_info_action_padding_v">

                            <ImageView
                                android:id="@+id/iv_player_info_fav"
                                android:layout_width="@dimen/player_info_action_icon_size"
                                android:layout_height="@dimen/player_info_action_icon_size"
                                android:contentDescription="@string/app_name"
                                android:src="@drawable/ic_action_fav"
                                app:tint="@color/player_button_tint" />

                            <TextView
                                android:id="@+id/tv_player_info_fav"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="@dimen/player_info_action_text_size" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_player_info_shelf_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/player_list_tab_parts"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/player_info_section_title_text_size"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_player_info_shelf"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingBottom="2dp" />

                    <TextView
                        android:id="@+id/tv_player_info_shelf_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/player_list_empty"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="@dimen/player_info_desc_text_size"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_player_info_recommend_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/player_list_tab_recommend"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/player_info_section_title_text_size"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_player_info_recommend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingBottom="2dp" />

                    <TextView
                        android:id="@+id/tv_player_info_recommend_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/player_info_recommend_empty"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="@dimen/player_info_desc_text_size"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/settings_panel"
        android:layout_width="@dimen/player_side_panel_width"
        android:layout_height="0dp"
        android:layout_margin="@dimen/player_side_panel_margin"
        android:layout_marginTop="@dimen/player_side_panel_margin_top"
        android:layout_marginBottom="@dimen/player_side_panel_margin_bottom"
        android:visibility="gone"
        app:cardBackgroundColor="#CC1E1E1E"
        app:cardCornerRadius="@dimen/player_side_panel_corner_radius"
        app:cardElevation="@dimen/player_side_panel_elevation"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/player_side_panel_padding">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_settings"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingStart="@dimen/player_side_panel_recycler_padding"
                android:paddingTop="@dimen/player_side_panel_recycler_padding"
                android:paddingEnd="@dimen/player_side_panel_recycler_padding"
                android:paddingBottom="@dimen/player_side_panel_recycler_padding"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/comments_panel"
        android:layout_width="@dimen/player_side_panel_width"
        android:layout_height="0dp"
        android:layout_margin="@dimen/player_side_panel_margin"
        android:layout_marginTop="@dimen/player_side_panel_margin_top"
        android:layout_marginBottom="@dimen/player_side_panel_margin_bottom"
        android:visibility="gone"
        app:cardBackgroundColor="#CC1E1E1E"
        app:cardCornerRadius="@dimen/player_side_panel_corner_radius"
        app:cardElevation="@dimen/player_side_panel_elevation"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/player_side_panel_padding">

            <LinearLayout
                android:id="@+id/row_comment_sort"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tv_comment_sort_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_comment_sort"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="@dimen/player_comment_sort_label_text_size" />

                <TextView
                    android:id="@+id/chip_comment_sort_hot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/player_comment_sort_chip_margin_start"
                    android:background="@drawable/bg_player_sort_chip"
                    android:clickable="true"
                    android:focusable="true"
                    android:nextFocusUp="@id/chip_comment_sort_hot"
                    android:nextFocusRight="@id/chip_comment_sort_new"
                    android:paddingHorizontal="@dimen/player_comment_sort_chip_padding_h"
                    android:paddingVertical="@dimen/player_comment_sort_chip_padding_v"
                    android:stateListAnimator="@animator/blbl_focus_scale"
                    android:text="@string/player_comment_sort_hot"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="@dimen/player_comment_sort_chip_text_size" />

                <TextView
                    android:id="@+id/chip_comment_sort_new"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/player_comment_sort_chip_margin_start"
                    android:background="@drawable/bg_player_sort_chip"
                    android:clickable="true"
                    android:focusable="true"
                    android:nextFocusLeft="@id/chip_comment_sort_hot"
                    android:nextFocusUp="@id/chip_comment_sort_new"
                    android:nextFocusRight="@id/chip_comment_sort_new"
                    android:paddingHorizontal="@dimen/player_comment_sort_chip_padding_h"
                    android:paddingVertical="@dimen/player_comment_sort_chip_padding_v"
                    android:stateListAnimator="@animator/blbl_focus_scale"
                    android:text="@string/player_comment_sort_new"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="@dimen/player_comment_sort_chip_text_size" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/comments_content"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/player_side_panel_content_margin_top"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/row_comment_sort">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_comments"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingStart="@dimen/player_side_panel_recycler_padding"
                    android:paddingTop="@dimen/player_side_panel_recycler_padding"
                    android:paddingEnd="@dimen/player_side_panel_recycler_padding"
                    android:paddingBottom="@dimen/player_side_panel_recycler_padding" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_comment_thread"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingStart="@dimen/player_side_panel_recycler_padding"
                    android:paddingTop="@dimen/player_side_panel_recycler_padding"
                    android:paddingEnd="@dimen/player_side_panel_recycler_padding"
                    android:paddingBottom="@dimen/player_side_panel_recycler_padding"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_comments_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="@dimen/player_comments_hint_padding"
                    android:text="@string/player_comment_loading"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="@dimen/player_comments_hint_text_size"
                    android:visibility="gone" />

            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</merge>
